rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Permitir acceso de lectura a cualquier persona (para que las imágenes del portafolio carguen públicamente)
    // Permitir escritura SOLO si el usuario está autenticado (Administrador del panel)
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
